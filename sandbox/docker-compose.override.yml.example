# docker-compose.override.yml.example — plugin-free build opt-out.
#
# Phase 2 plugin architecture: cozylobe (and any future declared lobes)
# now run as plugin s6 services INSIDE the main alice container, wired
# up at image build time by `sandbox/scripts/install-plugins.sh` against
# the manifest at `config/plugins.yaml`. The separate `cozylobe` sidecar
# / `--profile cozylobe` / `--target cozylobe` pattern from Phase 1 is
# retired — there is no `cozylobe` Dockerfile target anymore.
#
# Default behavior (no override file): `docker compose -f
# sandbox/docker-compose.yml up -d` builds the main image with all
# plugins installed and starts them under s6. Runtime opt-out for a
# specific plugin lives in its own env var
# (e.g. ALICE_COZYLOBE_ENABLED=false in alice.env idles cozylobe's two
# services without rebuilding).
#
# This override file is the BUILD-TIME opt-out: pass
# `INSTALL_PLUGINS=false` as a build arg to produce a plugin-free alice
# image (useful for CI smoke tests, or when iterating on the base image
# before publishing a plugin wheel).
#
# To use:
#
#   1. Copy this file (`.example` stripped) — the plain name is
#      gitignored so per-host customizations stay local:
#        cp sandbox/docker-compose.override.yml.example \
#           sandbox/docker-compose.override.yml
#
#   2. Build with the plugin-free arg and bring everything up:
#        docker compose -f sandbox/docker-compose.yml \
#                       -f sandbox/docker-compose.override.yml \
#                       up -d --build

services:
  alice:
    build:
      args:
        INSTALL_PLUGINS: "false"
