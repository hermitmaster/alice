#!/usr/bin/env bash
# alice-deploy — blue/green update for Alice.
#
#   alice-deploy worker               # build + swap the worker slot
#   alice-deploy worker --rollback    # swap back to the other (prior) slot
#   alice-deploy daemon               # update the daemon (brief reconnect)
#   alice-deploy all                  # daemon, then worker
#
# Architecture: two worker slots, blue and green. Exactly one is live (holds
# /state/worker/lease). Deploy alternates:
#
#   1. Detect live slot (flock probe). NEXT = the other slot.
#   2. Force-remove any leftover container in the NEXT slot — usually the
#      previous deploy's OLD container that finished draining. If a deploy
#      cadence outpaces thinker drain (rare), this SIGKILLs an in-flight
#      wake; the watchdog handles the consequences.
#   3. Build new image; tag as alice-worker:$NEXT.
#   4. `compose --profile $NEXT up -d alice-worker-$NEXT`. New container
#      starts, bridge blocks on flock (live still holds it).
#   5. SIGTERM live worker. The speaking bridge enters drain mode (finish
#      current turn + queued events, then exit) — fd 9 released, lease
#      transfers. The thinker keeps running, finishing its in-flight wake
#      in the background; the container only fully exits when every
#      service has drained.
#   6. NEXT worker's bridge unblocks, acquires lease, does catchup, resumes
#      processing — Alice is now talking from the new slot.
#   7. Detach a background cleanup that waits for the old container to
#      exit (= thinker also drained), then ``docker rm``s it. 30-minute
#      hard cap.
#
# Rollback: same flow but keep the NEXT slot's EXISTING image (don't rebuild).
# Since each slot's image tag points at whatever it was last deployed with,
# the other slot is always the last-known-good.

set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SANDBOX_DIR="$ALICE_ROOT/sandbox"
DRAIN_TIMEOUT="${DRAIN_TIMEOUT:-300}"
READY_TIMEOUT="${READY_TIMEOUT:-90}"
HEALTH_TIMEOUT="${HEALTH_TIMEOUT:-60}"
# Hard cap on background cleanup: how long we wait for the old container
# to exit naturally (= thinker finished its in-flight wake) before
# SIGKILLing it. 30 min covers any reasonable wake; longer than that is
# a hung wake the watchdog should have caught.
CLEANUP_TIMEOUT="${CLEANUP_TIMEOUT:-1800}"

# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

die() { echo "alice-deploy: $*" >&2; exit 1; }
log() { echo "[$(date '+%H:%M:%S')] $*"; }

usage() { sed -n '3,26p' "$0"; }

compose() {
    # All ALICE_* / USER_ID / GROUP_ID env vars are exported by
    # _alice-env.sh, so the subshell inherits them and docker compose
    # resolves the bind-mount paths consistently with alice-up. Without
    # this, the compose file's defaults (e.g. ${HOME}/alice-mind) take
    # effect and a deploy silently remounts the worker onto stub dirs
    # — disconnected from live state. See issue #2.
    ( cd "$SANDBOX_DIR" && docker compose "$@" )
}

# ---------- slot detection ----------
lease_held_in() {
    # Returns 0 if the container's bridge holds the lease.
    local name="$1"
    docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null | grep -q running || return 1
    ! docker exec "$name" flock -n /state/worker/lease true 2>/dev/null
}

detect_live_slot() {
    # Print "blue" or "green" for the currently-live slot. Exits 1 if neither.
    if lease_held_in alice-worker-blue; then echo blue; return 0; fi
    if lease_held_in alice-worker-green; then echo green; return 0; fi
    return 1
}

other_slot() {
    case "$1" in
        blue)  echo green ;;
        green) echo blue ;;
        *) die "unknown slot: $1" ;;
    esac
}

# ---------- readiness probes ----------
wait_bridge_running() {
    # Wait for the container to be running AND for the alice-speaking daemon
    # process to exist (even if it's still blocked on the flock — the process
    # being alive is what we care about here).
    local name="$1" timeout="${2:-$READY_TIMEOUT}"
    local i
    for ((i=0; i<timeout*2; i++)); do
        if docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null | grep -q running; then
            if docker exec "$name" pgrep -f alice_speaking >/dev/null 2>&1; then
                return 0
            fi
        fi
        sleep 0.5
    done
    return 1
}

wait_lease_held() {
    local name="$1" timeout="${2:-$READY_TIMEOUT}"
    local i
    for ((i=0; i<timeout*2; i++)); do
        if lease_held_in "$name"; then return 0; fi
        sleep 0.5
    done
    return 1
}

wait_daemon_healthy() {
    local timeout="${1:-$HEALTH_TIMEOUT}"
    local i
    for ((i=0; i<timeout*2; i++)); do
        [ "$(docker inspect -f '{{.State.Health.Status}}' alice-daemon 2>/dev/null || echo "")" = "healthy" ] \
            && return 0
        sleep 0.5
    done
    return 1
}

# ---------- worker deploy ----------
deploy_worker() {
    local mode="${1:-build}"     # 'build' or 'rollback'

    local live
    if ! live=$(detect_live_slot); then
        die "no live worker (neither blue nor green holds the lease)"
    fi
    local next
    next=$(other_slot "$live")
    log "live=$live  next=$next  mode=$mode"

    if [ "$mode" = "rollback" ]; then
        # Use whatever image $next currently has (= last deployed to that slot).
        docker image inspect "alice-worker:$next" >/dev/null 2>&1 \
            || die "no alice-worker:$next image to roll back to"
        log "Rolling back to existing alice-worker:$next"
    else
        log "Building alice-worker:$next ..."
        # compose build uses the :<next> tag from the compose config.
        compose --profile "$next" build "alice-worker-$next"
    fi

    # Clean up any stale container in the next slot from a prior failed deploy.
    docker rm -f "alice-worker-$next" >/dev/null 2>&1 || true

    log "Starting alice-worker-$next ..."
    compose --profile "$next" up -d --no-build "alice-worker-$next" >/dev/null

    log "Waiting for alice-worker-$next bridge to start ..."
    if ! wait_bridge_running "alice-worker-$next"; then
        log "alice-worker-$next failed to start"
        docker logs --tail 80 "alice-worker-$next" 2>&1 || true
        docker rm -f "alice-worker-$next" >/dev/null 2>&1 || true
        die "deploy aborted"
    fi

    log "SIGTERM → alice-worker-$live (speaking drains, lease releases) ..."
    docker kill --signal=SIGTERM "alice-worker-$live" 2>/dev/null || true

    log "Waiting for alice-worker-$next to acquire lease ..."
    if ! wait_lease_held "alice-worker-$next" "$DRAIN_TIMEOUT"; then
        log "drain timeout — SIGKILLing alice-worker-$live"
        docker kill "alice-worker-$live" 2>/dev/null || true
        if ! wait_lease_held "alice-worker-$next" 30; then
            docker logs --tail 80 "alice-worker-$next" 2>&1 || true
            docker rm -f "alice-worker-$next" >/dev/null 2>&1 || true
            die "deploy FAILED: next worker could not acquire lease"
        fi
    fi

    log "alice-worker-$next is live. Live slot is now $next."
    log "alice-worker-$live still draining (thinker may have an in-flight wake); cleanup detached."
    detach_old_container_cleanup "alice-worker-$live"
}

# Wait in the background for ``$1`` to exit naturally (the thinker
# supervisor finishes its in-flight wake, then s6 brings the container
# down) and ``docker rm`` it. ``CLEANUP_TIMEOUT`` (default 30 min) caps
# the wait — past that we SIGKILL on the assumption the wake is hung
# and the watchdog will surface it elsewhere. Disowned so the deploy
# script can return immediately; the subshell survives independent of
# the parent shell.
detach_old_container_cleanup() {
    local name="$1"
    (
        local deadline poll_interval=10
        deadline=$(( $(date +%s) + CLEANUP_TIMEOUT ))
        while [ "$(date +%s)" -lt "$deadline" ]; do
            local status
            status=$(docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null || echo missing)
            case "$status" in
                missing)
                    exit 0
                    ;;
                exited|dead)
                    docker rm "$name" >/dev/null 2>&1 || true
                    exit 0
                    ;;
            esac
            sleep "$poll_interval"
        done
        # Cap exceeded — assume hung wake; force-kill and reap.
        docker rm -f "$name" >/dev/null 2>&1 || true
    ) </dev/null >/dev/null 2>&1 &
    disown
}

# ---------- daemon deploy ----------
deploy_daemon() {
    log "Building alice-daemon ..."
    compose build alice-daemon

    log "Recreating alice-daemon (worker will briefly fail to reach it — messages buffer at Signal servers) ..."
    compose up -d --no-build --no-deps --force-recreate alice-daemon >/dev/null

    if ! wait_daemon_healthy; then
        die "daemon did not become healthy; check 'docker logs alice-daemon'"
    fi
    log "Daemon updated."
}

# ---------- dispatch ----------
case "${1:-}" in
    worker)
        if [ "${2:-}" = "--rollback" ]; then
            deploy_worker "rollback"
        else
            deploy_worker "build"
        fi
        ;;
    daemon)
        deploy_daemon
        ;;
    all)
        deploy_daemon
        deploy_worker "build"
        ;;
    -h|--help|"")
        usage
        ;;
    *)
        usage; exit 2 ;;
esac
