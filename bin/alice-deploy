#!/usr/bin/env bash
# alice-deploy — rebuild + relaunch the single Alice container.
#
#   alice-deploy                build, graceful stop, replace, verify.
#   alice-deploy --rollback     restore alice:premigration, replace, verify.
#   alice-deploy --dry-run      print what would happen, do nothing.
#
# Single-container shape (EKS Phase 2, #160). The compose service is
# `alice`; the image tag is `alice:latest`. Before every fresh build we
# re-tag the live image as `alice:premigration` so --rollback has a
# known-good anchor. The graceful stop relies on docker honoring
# `stop_grace_period: 30m` in sandbox/docker-compose.yml, which mirrors
# S6_SERVICES_GRACETIME inside the container — speaking and thinking get
# the same window to drain that the legacy 3-svc layout's
# CLEANUP_TIMEOUT used to give the detached cleanup goroutine.
#
# Health = the viewer's `/` returning 200. The sanity probe re-confirms
# that the four critical s6 services (signal-daemon, alice-speaking,
# alice-thinker, alice-viewer) are up, which catches the case where the
# viewer comes up but a peer service crash-loops behind it.

set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SANDBOX_DIR="$ALICE_ROOT/sandbox"
HEALTH_TIMEOUT="${HEALTH_TIMEOUT:-90}"
SERVICE_PROBE_TIMEOUT="${SERVICE_PROBE_TIMEOUT:-60}"
HEALTH_URL="${HEALTH_URL:-http://127.0.0.1:7777/}"
CONTAINER="alice"
IMAGE="alice:latest"
PREMIG_IMAGE="alice:premigration"
S6_SERVICES=(signal-daemon alice-speaking alice-thinker alice-viewer)

# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

DRY_RUN=0
MODE=deploy

die() { echo "alice-deploy: $*" >&2; exit 1; }
log() { echo "[$(date '+%H:%M:%S')] $*"; }

usage() {
    cat <<'USAGE'
alice-deploy — rebuild + relaunch the single Alice container.

Usage:
    alice-deploy                Build, graceful stop, replace, verify.
    alice-deploy --rollback     Restore alice:premigration and replace.
    alice-deploy --dry-run      Print what would happen, do nothing.
    alice-deploy -h | --help    This help.
USAGE
}

while [ $# -gt 0 ]; do
    case "$1" in
        --rollback) MODE=rollback ;;
        --dry-run)  DRY_RUN=1 ;;
        -h|--help)  usage; exit 0 ;;
        *)          usage; exit 2 ;;
    esac
    shift
done

# Pre-flight. Mirrors alice-up so a misconfigured host fails before the
# tagging/build dance starts. Skipped in dry-run so the dry-run can be
# used on a host without docker (e.g. CI shell-syntax checks).
if [ "$DRY_RUN" != 1 ]; then
    command -v docker >/dev/null 2>&1 \
        || die "docker not found on PATH. Install Docker and retry."
    docker info >/dev/null 2>&1 \
        || die "docker daemon isn't running (or your user can't reach it)."
fi
[ -f "$SANDBOX_DIR/docker-compose.yml" ] \
    || die "compose file missing: $SANDBOX_DIR/docker-compose.yml"

run() {
    if [ "$DRY_RUN" = 1 ]; then
        echo "[dry-run] $*"
    else
        "$@"
    fi
}

compose() {
    # All ALICE_* / USER_ID / GROUP_ID env vars are exported by
    # _alice-env.sh, so the subshell inherits them and docker compose
    # resolves the bind-mount paths consistently with alice-up. Without
    # this, the compose file's defaults (e.g. ${HOME}/alice-mind) take
    # effect and a deploy silently remounts the container onto stub dirs
    # — disconnected from live state. See issue #2.
    if [ "$DRY_RUN" = 1 ]; then
        echo "[dry-run] (cd $SANDBOX_DIR && docker compose $*)"
        return 0
    fi
    ( cd "$SANDBOX_DIR" && docker compose "$@" )
}

image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

container_running() {
    [ "$(docker inspect -f '{{.State.Status}}' "$CONTAINER" 2>/dev/null || true)" = "running" ]
}

wait_health() {
    local url="$1" timeout="${2:-$HEALTH_TIMEOUT}"
    local i
    for ((i=0; i<timeout*2; i++)); do
        if curl -sf -o /dev/null "$url" 2>/dev/null; then
            return 0
        fi
        sleep 0.5
    done
    return 1
}

verify_s6_services() {
    # `s6-svstat` is at `/command/s6-svstat` — not on the `docker exec` PATH.
    # Its first output token is "up" or "down"; we poll until every
    # named service reports "up" or we hit the timeout. Long-running
    # service startup (sci-env venv pull, embedder warmup) means we
    # can't assume all four are up the instant the viewer answers 200.
    local timeout="${SERVICE_PROBE_TIMEOUT}"
    local svc i status ok
    for svc in "${S6_SERVICES[@]}"; do
        ok=0
        for ((i=0; i<timeout*2; i++)); do
            status=$(docker exec "$CONTAINER" /command/s6-svstat "/run/service/$svc" 2>/dev/null || true)
            case "$status" in
                up\ *) ok=1; break ;;
            esac
            sleep 0.5
        done
        if [ "$ok" != 1 ]; then
            log "s6 service $svc not up: ${status:-<no status>}"
            return 1
        fi
        log "s6 service $svc: up"
    done
    return 0
}

graceful_stop() {
    if ! container_running; then
        log "$CONTAINER not running; nothing to stop."
        return 0
    fi
    # `docker compose stop` sends SIGTERM and waits up to the
    # stop_grace_period configured in docker-compose.yml (30m). s6's
    # drain hooks then run speaking + thinking through their queue
    # before the container exits.
    log "Stopping $CONTAINER (graceful, up to compose stop_grace_period) ..."
    compose stop "$CONTAINER"
}

post_up_verify() {
    local label="$1"
    log "Probing $HEALTH_URL (timeout ${HEALTH_TIMEOUT}s) ..."
    if [ "$DRY_RUN" != 1 ] && ! wait_health "$HEALTH_URL" "$HEALTH_TIMEOUT"; then
        docker logs --tail 80 "$CONTAINER" 2>&1 || true
        die "$label aborted: viewer never returned 200 at $HEALTH_URL"
    fi
    log "Verifying s6 services: ${S6_SERVICES[*]} ..."
    if [ "$DRY_RUN" != 1 ] && ! verify_s6_services; then
        docker logs --tail 80 "$CONTAINER" 2>&1 || true
        die "$label aborted: one or more s6 services not up"
    fi
}

deploy() {
    log "mode=deploy"
    # Snapshot the live image as the rollback anchor BEFORE building.
    # `docker compose build` would otherwise overwrite alice:latest and
    # the prior image would only be reachable by SHA. Skipped on first
    # deploy when alice:latest doesn't exist yet.
    if image_exists "$IMAGE"; then
        log "Tagging $IMAGE -> $PREMIG_IMAGE (rollback anchor) ..."
        run docker tag "$IMAGE" "$PREMIG_IMAGE"
    else
        log "$IMAGE not present; skipping premigration tag (first deploy)."
    fi

    log "Building $IMAGE ..."
    compose build alice

    graceful_stop

    log "Bringing up $CONTAINER ..."
    compose up -d --no-build alice

    post_up_verify "deploy"
    log "Deploy complete. $IMAGE is live; previous image preserved as $PREMIG_IMAGE."
}

rollback() {
    log "mode=rollback"
    if [ "$DRY_RUN" != 1 ] && ! image_exists "$PREMIG_IMAGE"; then
        die "no $PREMIG_IMAGE to roll back to (deploy at least once first)"
    fi

    graceful_stop

    log "Restoring $PREMIG_IMAGE -> $IMAGE ..."
    run docker tag "$PREMIG_IMAGE" "$IMAGE"

    # --force-recreate: the image content didn't change, just the tag's
    # SHA. Compose's "is recreate needed" check is content-based; without
    # the flag it can leave the existing container in place.
    log "Bringing up $CONTAINER ..."
    compose up -d --no-build --force-recreate alice

    post_up_verify "rollback"
    log "Rollback complete. $IMAGE now points at the prior image."
}

case "$MODE" in
    deploy)   deploy ;;
    rollback) rollback ;;
esac
