#!/usr/bin/env python3
"""alice-client — speaks the CLITransport socket protocol.

Runs *inside* the worker container (the host wrapper at bin/alice does
the docker-exec dance). Connects to ``/tmp/alice.sock`` (override with
``ALICE_CLI_SOCKET``), sends a message, and prints Alice's reply chunks
to stdout until she signals ``done``.

Three modes:

    alice-client -p "what's on today?"   # one-shot prompt — print and exit
    alice-client                          # interactive — REPL over the
                                          # same socket; one connection,
                                          # many turns
    alice-client --context                # one-shot context snapshot RPC;
                                          # human-readable by default,
                                          # raw JSON with --json

A ``--json`` flag emits the raw event stream (one JSON event per line)
to stdout instead of human-friendly chunks. Useful for agents driving
Alice programmatically — and what the viewer's /context tab consumes.

Exit codes:
    0   one or more turns completed (or interactive mode exited cleanly)
    1   protocol or transport error (socket missing, malformed event)
    2   Alice replied with type=error
    3   client error (bad arguments, can't reach socket)

Stays small on purpose — no third-party deps, just stdlib.
"""

from __future__ import annotations

import argparse
import json
import os
import pathlib
import socket
import sys
from typing import Iterator, Optional


DEFAULT_SOCKET = "/tmp/alice.sock"


def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="alice-client",
        description="Talk to Alice over the local CLI transport socket.",
    )
    p.add_argument(
        "-p",
        "--prompt",
        help="One-shot prompt. If absent, run an interactive REPL.",
    )
    p.add_argument(
        "--socket",
        default=os.environ.get("ALICE_CLI_SOCKET", DEFAULT_SOCKET),
        help=f"Path to alice's socket (default: {DEFAULT_SOCKET})",
    )
    p.add_argument(
        "--json",
        action="store_true",
        dest="json_mode",
        help="Emit raw JSON events to stdout (one per line). For agents.",
    )
    p.add_argument(
        "--timeout",
        type=float,
        default=None,
        help="Per-turn timeout in seconds (default: no timeout).",
    )
    p.add_argument(
        "--context",
        action="store_true",
        help=(
            "One-shot context-snapshot RPC. Prints the live daemon's "
            "context composition (system prompt, tools, MCP, session) "
            "and exits."
        ),
    )
    p.add_argument(
        "--no-text",
        action="store_true",
        dest="no_text",
        help=(
            "With --context: omit system_prompt and pending_preamble "
            "bodies (sizes only). Cheaper to ship over the wire."
        ),
    )
    return p.parse_args(argv)


def connect(path: str) -> socket.socket:
    if not pathlib.Path(path).exists():
        sys.stderr.write(
            f"alice-client: socket not found at {path}\n"
            "is the alice-speaking service running?\n"
        )
        sys.exit(3)
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(path)
    except (PermissionError, ConnectionRefusedError, FileNotFoundError) as exc:
        sys.stderr.write(f"alice-client: cannot connect to {path}: {exc}\n")
        sys.exit(3)
    return sock


def send_message(sock: socket.socket, text: str) -> None:
    payload = json.dumps({"type": "message", "text": text}) + "\n"
    sock.sendall(payload.encode("utf-8"))


def event_stream(sock: socket.socket) -> Iterator[dict]:
    """Read newline-delimited JSON events from the socket."""
    buf = b""
    while True:
        try:
            chunk = sock.recv(65536)
        except (ConnectionError, OSError):
            return
        if not chunk:
            return
        buf += chunk
        while b"\n" in buf:
            line, buf = buf.split(b"\n", 1)
            if not line.strip():
                continue
            try:
                yield json.loads(line.decode("utf-8"))
            except (json.JSONDecodeError, UnicodeDecodeError) as exc:
                sys.stderr.write(f"alice-client: malformed event: {exc}\n")


def drain_one_turn(
    sock: socket.socket,
    *,
    json_mode: bool,
    timeout: Optional[float],
) -> int:
    """Read events until ``done`` or ``error``. Returns an exit hint:
    0 on success, 2 on Alice-reported error.
    """
    if timeout is not None:
        sock.settimeout(timeout)
    error_seen = False
    for event in event_stream(sock):
        if json_mode:
            sys.stdout.write(json.dumps(event) + "\n")
            sys.stdout.flush()
        etype = event.get("type")
        if etype == "chunk":
            if not json_mode:
                sys.stdout.write(event.get("text", ""))
                sys.stdout.flush()
        elif etype == "error":
            error_seen = True
            if not json_mode:
                sys.stderr.write(
                    "alice-client: error from alice: "
                    f"{event.get('message', 'unspecified')}\n"
                )
        elif etype == "done":
            if not json_mode:
                # Trailing newline so the prompt sits on its own line.
                sys.stdout.write("\n")
                sys.stdout.flush()
            return 2 if error_seen else 0
        # ack / tool_use / unknown — pass through (json mode only).
    # Stream ended without "done" — connection died.
    if not json_mode:
        sys.stderr.write("\nalice-client: connection closed before turn ended\n")
    return 1


def run_one_shot(sock: socket.socket, args: argparse.Namespace) -> int:
    send_message(sock, args.prompt)
    return drain_one_turn(sock, json_mode=args.json_mode, timeout=args.timeout)


def run_interactive(sock: socket.socket, args: argparse.Namespace) -> int:
    """Two modes:

    - ``--json`` (TUIs / agents wanting raw events): a background thread
      drains the socket continuously so server-pushed events (surface
      wakes, emergency dispatches, anything not tied to *this* prompt)
      reach the consumer immediately. Without this, async pushes sit in
      the kernel buffer until the next stdin send wakes the reader.
    - human REPL (no ``--json``): the original synchronous drain-on-turn
      loop. Keeps `> ` prompt sane and avoids interleaved output mid-edit.
    """
    if args.json_mode:
        return _run_interactive_async(sock, args)
    return _run_interactive_sync(sock, args)


def _run_interactive_sync(sock: socket.socket, args: argparse.Namespace) -> int:
    sys.stderr.write(
        "alice-client: interactive mode (Ctrl-D to exit). Type a message and press Enter.\n"
    )
    while True:
        sys.stderr.write("> ")
        sys.stderr.flush()
        try:
            line = sys.stdin.readline()
        except KeyboardInterrupt:
            sys.stderr.write("\n")
            return 0
        if not line:
            sys.stderr.write("\n")
            return 0
        text = line.rstrip("\n")
        if not text.strip():
            continue
        send_message(sock, text)
        rc = drain_one_turn(sock, json_mode=False, timeout=args.timeout)
        if rc == 1:
            # Connection problem — exit. (Alice-reported errors continue.)
            return 1


def _run_interactive_async(sock: socket.socket, args: argparse.Namespace) -> int:
    """JSON-mode REPL with a background socket reader.

    The reader thread pumps every event through stdout the moment it
    arrives — including ones that originate from a turn the consumer
    didn't initiate (surface wakes pushing notifications, emergency
    chunks, etc.). The main thread just forwards stdin lines to the
    socket; turn boundary tracking is the consumer's job.
    """
    import threading

    if args.timeout is not None:
        sock.settimeout(args.timeout)

    stop = threading.Event()
    exit_code = [0]

    def reader() -> None:
        try:
            for event in event_stream(sock):
                if stop.is_set():
                    return
                sys.stdout.write(json.dumps(event) + "\n")
                sys.stdout.flush()
            # event_stream returned → socket closed by peer
            stop.set()
            exit_code[0] = 1
        except Exception:  # noqa: BLE001
            stop.set()
            exit_code[0] = 1

    t = threading.Thread(target=reader, name="alice-client-reader", daemon=True)
    t.start()

    while not stop.is_set():
        try:
            line = sys.stdin.readline()
        except KeyboardInterrupt:
            break
        if not line:  # EOF
            break
        text = line.rstrip("\n")
        if not text.strip():
            continue
        try:
            send_message(sock, text)
        except (BrokenPipeError, ConnectionError, OSError):
            # Reader thread will set stop on socket close; exit cleanly.
            break

    stop.set()
    return exit_code[0]


def run_context_request(sock: socket.socket, args: argparse.Namespace) -> int:
    """One-shot context-snapshot RPC. Sends ``{"type": "context", ...}``,
    drains the reply, and either prints a human-readable summary or
    forwards the raw JSON events.

    Exit codes match the message path: 0 success, 1 protocol failure,
    2 server-reported error.
    """
    payload = {"type": "context", "include_text": not args.no_text}
    sock.sendall((json.dumps(payload) + "\n").encode("utf-8"))
    if args.timeout is not None:
        sock.settimeout(args.timeout)
    snapshot: Optional[dict] = None
    error_seen = False
    for event in event_stream(sock):
        if args.json_mode:
            sys.stdout.write(json.dumps(event) + "\n")
            sys.stdout.flush()
        etype = event.get("type")
        if etype == "context_snapshot":
            snapshot = event.get("data") or {}
        elif etype == "error":
            error_seen = True
            if not args.json_mode:
                sys.stderr.write(
                    "alice-client: error from alice: "
                    f"{event.get('message', 'unspecified')}\n"
                )
        elif etype == "done":
            break
    if error_seen:
        return 2
    if not args.json_mode:
        if snapshot is None:
            sys.stderr.write("alice-client: no snapshot received before done\n")
            return 1
        _print_context_snapshot(snapshot)
    return 0


def _print_context_snapshot(snap: dict) -> None:
    """Render a context snapshot as a debug-friendly text block on stdout."""
    out = sys.stdout.write
    out("alice context snapshot\n")
    out(f"  model:        {snap.get('model') or '?'}\n")
    out(f"  backend:      {snap.get('backend') or '?'}\n")
    out(f"  session_id:   {snap.get('session_id') or '(none — cold start)'}\n")
    in_flight = snap.get("in_flight")
    if in_flight:
        out(f"  in_flight:    yes (kind={in_flight.get('turn_kind')})\n")
    else:
        out("  in_flight:    no\n")
    out(f"  mind_dir:     {snap.get('mind_dir') or '?'}\n")
    out(f"  skills_cwd:   {snap.get('skills_cwd') or '?'}\n")
    sp = snap.get("system_prompt") or {}
    out(f"  system prompt: {sp.get('chars', 0)} chars\n")
    preamble = snap.get("pending_preamble")
    if preamble:
        out(f"  pending preamble: {preamble.get('chars', 0)} chars\n")
    else:
        out("  pending preamble: none\n")
    tools = snap.get("tools") or {}
    builtin = tools.get("builtin") or []
    custom = tools.get("custom") or []
    out(
        f"  tools:        {tools.get('count', 0)} total "
        f"({len(builtin)} builtin + {len(custom)} custom)\n"
    )
    if builtin:
        out(f"    builtin:    {', '.join(builtin)}\n")
    mcp = snap.get("mcp_servers") or {}
    if mcp:
        out(f"  MCP servers ({len(mcp)}):\n")
        for name in sorted(mcp.keys()):
            spec = mcp[name] or {}
            out(
                f"    {name} ({spec.get('type', '?')}): "
                f"{spec.get('tool_count', 0)} tools\n"
            )
            for tool in spec.get("tool_names") or []:
                out(f"      - {tool}\n")
    sys.stdout.flush()


def main(argv: Optional[list[str]] = None) -> int:
    args = parse_args(argv if argv is not None else sys.argv[1:])
    sock = connect(args.socket)
    try:
        if args.context:
            return run_context_request(sock, args)
        if args.prompt is not None:
            return run_one_shot(sock, args)
        return run_interactive(sock, args)
    finally:
        try:
            sock.shutdown(socket.SHUT_RDWR)
        except OSError:
            pass
        sock.close()


if __name__ == "__main__":
    sys.exit(main())
