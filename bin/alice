#!/usr/bin/env bash
# Talk to Alice over the local CLI transport socket inside her sandbox.
#
# Single-container shape: there's exactly one `alice` container (its
# name lives in $ALICE_CONTAINER via _alice-env.sh, default `alice`),
# so the call always lands on the live speaking daemon — no
# blue/green slot election to do.
#
# Usage:
#   alice                           # interactive REPL
#   alice "what's on today?"        # one-shot prompt
#   alice -p "what's on today?"     # one-shot prompt (explicit -p)
#   alice --json -p "..."           # raw JSON event stream (for agents)
#   alice context                   # one-shot context-snapshot RPC
#   alice context --json            # same, raw JSON (viewer / agents)
#
# Talks to /state/alice.sock via /usr/local/bin/alice-client baked
# into the sandbox image. The legacy `claude`-based path spawned a
# fresh agent with no Alice context; this path goes through the
# running speaking daemon, so the CLI gets real Alice (mind repo,
# session continuity, MCP tools).
set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

"$ALICE_ROOT/bin/alice-up"

# Build the args we'll pass to alice-client. Bare `alice "prompt"` is
# friendlier than requiring -p; we promote a non-flag first arg into a
# -p prompt. The literal verb `context` is special-cased into the
# context-RPC subcommand so callers can write `alice context --json`
# without remembering the underlying flag. Everything starting with -
# or -- passes through unchanged.
client_args=()
if [ "$#" -ge 1 ] && [ "$1" = "context" ]; then
    shift
    client_args=(--context "$@")
elif [ "$#" -ge 1 ] && [[ "$1" != -* ]]; then
    client_args=(-p "$*")
else
    client_args=("$@")
fi

# Interactive vs one-shot decided by alice-client based on -p presence.
# We just need the right docker-exec shape: -t when stdin+stdout are
# both terminals (interactive REPL), -i otherwise (pipe-friendly).
if [ -t 0 ] && [ -t 1 ] && [ "$#" -eq 0 ]; then
    exec docker exec -u alice -it "$ALICE_CONTAINER" /usr/local/bin/alice-client ${client_args[@]+"${client_args[@]}"}
else
    exec docker exec -u alice -i "$ALICE_CONTAINER" /usr/local/bin/alice-client ${client_args[@]+"${client_args[@]}"}
fi
