#!/usr/bin/env bash
# Drop into a bash shell inside Alice's sandbox.
#
# Single-container shape: one `alice` container, no daemon/worker
# split. The legacy `daemon` / `worker` positional is still accepted
# (logs a one-liner) so muscle-memory invocations keep working.
set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

"$ALICE_ROOT/bin/alice-up"

case "${1:-}" in
    ""|worker|daemon)
        if [ "${1:-}" = "daemon" ] || [ "${1:-}" = "worker" ]; then
            echo "alice-shell: '$1' is a legacy target; the consolidated container has no separate daemon/worker. Shelling into $ALICE_CONTAINER." >&2
        fi
        exec docker exec -u alice -it "$ALICE_CONTAINER" bash
        ;;
    *)
        echo "alice-shell: unknown target '$1' (no positional needed in single-container shape)" >&2
        exit 2
        ;;
esac
