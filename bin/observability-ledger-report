#!/usr/bin/env python3
"""Observability ledger report — diagnostic summary of implicit signals.

Usage:
  observability-ledger-report                          # all signals, all time
  observability-ledger-report --signal-type NAME       # one signal type
  observability-ledger-report --since 2026-06-01       # filter by start time
  observability-ledger-report --json                   # machine-readable output

Reads ``~/alice-mind/inner/state/observability-ledger.json`` via the
:mod:`core.observability_ledger` helpers. Pure read path — does not
mutate the ledger.
"""

from __future__ import annotations

import argparse
import json
import sys
from collections import Counter

from core.observability_ledger import SIGNAL_TYPES, query_signals


def _summarise(entries: list[dict]) -> dict:
    total = len(entries)
    useful_count = sum(1 for e in entries if e.get("useful"))
    outcomes = Counter(e.get("outcome", "unknown") for e in entries)
    return {
        "total": total,
        "useful": useful_count,
        "useful_pct": round(useful_count / total * 100, 1) if total else 0.0,
        "outcomes": dict(outcomes),
        "recent": entries[-5:],
    }


def _format_block(signal_type: str, summary: dict) -> str:
    lines = [f"Signal: {signal_type}"]
    lines.append(f"  Total entries: {summary['total']}")
    lines.append(
        f"  Useful: {summary['useful']} ({summary['useful_pct']}%)"
    )
    if summary["outcomes"]:
        lines.append("  Outcomes:")
        for outcome, count in sorted(summary["outcomes"].items()):
            lines.append(f"    {outcome}: {count}")
    else:
        lines.append("  No entries in window.")
    if summary["recent"]:
        lines.append("  Recent (up to 5):")
        for entry in summary["recent"]:
            ts = entry.get("ts", "?")
            outcome = entry.get("outcome", "?")
            useful = "useful" if entry.get("useful") else "not-useful"
            lines.append(f"    {ts}  {outcome}  ({useful})")
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Observability ledger report"
    )
    parser.add_argument(
        "--signal-type",
        choices=SIGNAL_TYPES,
        help="Restrict report to a single signal type.",
    )
    parser.add_argument(
        "--since",
        metavar="ISO",
        help="Only count entries with ts >= ISO (e.g. 2026-06-01 or "
        "2026-06-01T00:00:00-04:00).",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit JSON instead of the human-readable report.",
    )
    args = parser.parse_args(argv)

    types = [args.signal_type] if args.signal_type else SIGNAL_TYPES

    report: dict[str, dict] = {}
    for sig in types:
        entries = query_signals(signal_type=sig, since_iso=args.since)
        report[sig] = _summarise(entries)

    if args.json:
        json.dump(report, sys.stdout, indent=2, default=str)
        sys.stdout.write("\n")
        return 0

    print("Observability Ledger Report")
    if args.since:
        print(f"  Since: {args.since}")
    print("=" * 40)
    for sig in types:
        print(_format_block(sig, report[sig]))
        print()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
