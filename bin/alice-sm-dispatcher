#!/usr/bin/env bash
# alice-sm-dispatcher — one pass of the State Machine v0 dispatcher.
#
# Polls jcronq/alice for open issues labeled sm:selected, applies the
# v0 trust filter, and posts a one-time `[SM] dispatcher-hello ...`
# comment per newly-seen issue. Dedup state lives at
# /state/worker/sm-dispatcher-state.json.
#
# Singleton enforcement is external — the s6 supervisor wraps each
# invocation in `flock -n /state/worker/sm-dispatcher.lock` so a slow
# poll can't double-fire.
#
# Exit codes (from alice_sm.dispatcher):
#   0  poll OK (zero or more comments posted)
#   non-zero  auth / rate-limit / internal error — supervisor sleeps
#             one cadence and tries again, same as alice-gh-watcher.
set -u

VENV_PY="/opt/alice-venv/bin/python"
ALICE_SRC="${ALICE_SRC:-/home/alice/alice/src}"

if [ ! -x "$VENV_PY" ]; then
    echo "[alice-sm-dispatcher] venv python missing at $VENV_PY" >&2
    exit 2
fi

export PYTHONPATH="$ALICE_SRC"
export PYTHONUNBUFFERED=1
exec "$VENV_PY" -m alice_sm.dispatcher "$@"
