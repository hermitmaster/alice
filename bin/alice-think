#!/usr/bin/env bash
# alice-think — one wake of Alice's thinking hemisphere.
#
# Thin shim over `python -m alice_thinking` (the Agent SDK avoids the
# `claude -p` TTY-detection hang per Issue #9026). The Python entry is
# where config overrides, prompt assembly, and the kernel.run() call live.
#
# Usage:
#   alice-think                  # full wake, reads prompts/thinking-bootstrap.md
#   alice-think --quick          # 30s plumbing smoke test
#   alice-think --echo           # also emit events to stderr
#   alice-think --max-seconds 0  # unbounded (default — no timeout)
#   alice-think --max-seconds 90 # cap wake at 90s for faster iteration
#
# Singleton enforcement is external — alice-thinker's supervisor wraps each
# invocation in `flock -n /state/worker/thinking.lock`.
set -u

VENV_PY="/opt/alice-venv/bin/python"
# Monorepo root is bind-mounted at /home/alice/alice; src/ holds all four
# packages (core, alice_speaking, alice_thinking, viewer).
ALICE_SRC="${ALICE_SRC:-/home/alice/alice/src}"

# Outer timeout (Phase 1 of wake-robustness design — see issue #105 and
# cortex-memory/research/2026-05-07-wake-robustness-outer-timeout-design.md).
# The Python interpreter can block indefinitely in post-return cleanup
# (epoll_wait on a leaked SDK socket) and silently halt the entire wake
# cadence by holding flock. `max_wake_seconds` only governs the inside of
# the wake loop; this caps the whole process. SIGTERM at WAKE_TIMEOUT,
# SIGKILL WAKE_KILL_GRACE seconds later if Python is still stuck.
WAKE_TIMEOUT="${WAKE_TIMEOUT:-1200}"
WAKE_KILL_GRACE="${WAKE_KILL_GRACE:-60}"

if [ ! -x "$VENV_PY" ]; then
    echo "[alice-think] venv python missing at $VENV_PY" >&2
    exit 1
fi

export PYTHONPATH="$ALICE_SRC"
export PYTHONUNBUFFERED=1
exec timeout --kill-after="$WAKE_KILL_GRACE" "$WAKE_TIMEOUT" "$VENV_PY" -m alice_thinking "$@"
