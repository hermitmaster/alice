#!/usr/bin/env bash
# Start Alice's sandbox if not already running. Idempotent.
# Readiness = the single `alice` container is up and its compose
# healthcheck reports `healthy` (viewer's `/` returning 200, per
# sandbox/Dockerfile).
#
# Single-container shape (EKS Phase 2, #160): no daemon/worker split,
# no blue/green, no worker-lease flock — one `alice` service supervised
# by s6-overlay. Rebuild-and-relaunch lives in alice-deploy.
set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ALICE_ROOT/sandbox"

if ! command -v docker >/dev/null 2>&1; then
    echo "alice-up: docker not found on PATH. Install Docker (or Docker Desktop) and retry." >&2
    exit 1
fi
if ! docker info >/dev/null 2>&1; then
    echo "alice-up: docker daemon isn't running (or your user can't reach it). Start it and retry." >&2
    exit 1
fi

# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

# Pre-create host directories that compose binds. If we don't, the docker
# daemon creates them as root:root on first run and Alice (uid 1000) can't
# write. Idempotent.
mkdir -p \
    "$ALICE_MIND" \
    "$ALICE_TOOLS" \
    "$HOME/.config/alice" \
    "$HOME/.config/gh" \
    "$HOME/.alice-claude" \
    "$HOME/.local/state/alice" \
    "$HOME/.local/share/signal-cli"

# Banner: which optional services are wired up this run. Read once so
# we don't print a different state mid-run if alice.env is edited under
# us. Stays under each service line so an operator can spot a misconfig
# without grepping container logs.
_print_banner() {
    if [ -n "${ALICE_WS_GATEWAY_TOKEN:-}" ]; then
        echo "alice-up: WS gateway listening on :${ALICE_WS_GATEWAY_PORT:-8765} (path ${ALICE_WS_GATEWAY_PATH:-/cli})"
    fi
    if [ -n "${DISCORD_BOT_TOKEN:-}" ]; then
        echo "alice-up: discord transport enabled (bot token present)"
    fi
    if [ "${ALICE_A2A_ENABLED:-0}" = "1" ] || [ "${ALICE_A2A_ENABLED:-}" = "true" ]; then
        echo "alice-up: A2A transport listening on :${ALICE_A2A_PORT:-7878}"
    fi
}

# Is the container already up? Noop unless it's stuck unhealthy.
state="$(docker inspect -f '{{.State.Status}}' "$ALICE_CONTAINER" 2>/dev/null || echo missing)"
if [ "$state" = "running" ]; then
    health="$(docker inspect -f '{{.State.Health.Status}}' "$ALICE_CONTAINER" 2>/dev/null || echo none)"
    case "$health" in
        healthy|starting|none) _print_banner; exit 0 ;;
    esac
fi

# First-run build only. Routine rebuilds after a `git pull` belong to
# alice-deploy — that path also re-tags the previous image as
# `alice:premigration` so --rollback has an anchor; alice-up touching
# the build would silently obliterate that anchor.
if ! docker image inspect alice:latest >/dev/null 2>&1; then
    docker compose build alice >/dev/null
fi

docker compose up -d alice >/dev/null

# Wait for the docker healthcheck to flip to healthy. ~45 s matches the
# worker-lease wait the legacy alice-up used; the viewer typically
# reports 200 within ~5–10 s of an `up`.
for _ in $(seq 1 90); do
    state="$(docker inspect -f '{{.State.Status}}' "$ALICE_CONTAINER" 2>/dev/null || echo missing)"
    if [ "$state" = "running" ]; then
        health="$(docker inspect -f '{{.State.Health.Status}}' "$ALICE_CONTAINER" 2>/dev/null || echo none)"
        case "$health" in
            healthy) _print_banner; exit 0 ;;
            unhealthy)
                echo "alice-up: container $ALICE_CONTAINER reported unhealthy" >&2
                exit 1
                ;;
        esac
    fi
    sleep 0.5
done

echo "alice-up: $ALICE_CONTAINER did not become healthy within 45s" >&2
exit 1
