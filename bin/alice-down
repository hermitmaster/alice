#!/usr/bin/env bash
# Stop Alice's sandbox. Use --rm to also remove the container
# (named volumes / bind mounts persist either way).
#
# Single-container shape: there's one `alice` service to stop. The
# stop honors compose's stop_grace_period (30m) so an in-flight
# speaking turn or thinker wake gets the full drain window before
# SIGKILL.
set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=./_alice-env.sh
. "$ALICE_ROOT/bin/_alice-env.sh"

cd "$ALICE_ROOT/sandbox"

if [ "${1:-}" = "--rm" ]; then
    docker compose down
else
    docker compose stop
fi
